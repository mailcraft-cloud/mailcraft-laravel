{
    "name": "mailcraft/mailcraft-laravel",
    "description": "Official Laravel SDK for MailCraft — transactional email with AI-generated content",
    "type": "library",
    "license": "MIT",
    "keywords": ["email", "transactional", "mailcraft", "laravel", "ai"],
    "homepage": "https://github.com/mailcraft-cloud/mailcraft-laravel",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "MailCraft\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailCraft\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MailCraft\\MailCraftServiceProvider"
            ],
            "aliases": {
                "MailCraft": "MailCraft\\Facades\\MailCraft"
            }
        }
    },
    "minimum-stability": "stable"
}
